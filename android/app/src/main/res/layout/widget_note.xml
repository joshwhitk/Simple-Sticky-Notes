<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="6dp">

    <!-- Title wraps onto multiple lines (down into the body area) so long titles
         stay readable in a 1x1 widget; it's still the first line when opened. -->
    <TextView
        android:id="@+id/w_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="4"
        android:ellipsize="end"
        android:textColor="@color/sticky_text"
        android:textStyle="bold"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/w_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:textColor="@color/sticky_text"
        android:textSize="13sp" />
</LinearLayout>
